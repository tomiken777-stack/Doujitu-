struct HistoryView: View {
    @ObservedObject var vm: DoujituVM
    @Environment(\.dismiss) var dismiss
    @State private var showDeleteConfirm = false
    
    // 日付と時刻のフォーマッターを追加
    private let dateFormatter: DateFormatter = {
        let formatter = DateFormatter()
        formatter.dateStyle = .medium
        formatter.timeStyle = .none
        formatter.locale = Locale(identifier: "ja_JP")
        return formatter
    }()
    
    private let timeFormatter: DateFormatter = {
        let formatter = DateFormatter()
        formatter.dateStyle = .none
        formatter.timeStyle = .short
        return formatter
    }()
    
    // 日付が変わったかを判定する関数
    private func isNewDay(for index: Int) -> Bool {
        if index == 0 { return true }
        let current = vm.logs[index].timestamp
        let previous = vm.logs[index - 1].timestamp
        return !Calendar.current.isDate(current, inSameDayAs: previous)
    }
    
    var body: some View {
        NavigationStack {
            ScrollView {
                LazyVStack(spacing: 16) {
                    if vm.logs.isEmpty {
                        Text("履歴がありません").foregroundColor(.secondary).padding(.top, 50)
                    }
                    
                    // 日付区切りと時間を表示するために indices を使用
                    ForEach(vm.logs.indices, id: \.self) { index in
                        let log = vm.logs[index]
                        
                        // 日付が変わった場合のみ日付区切りを表示
                        if isNewDay(for: index) {
                            Text(dateFormatter.string(from: log.timestamp))
                                .font(.caption)
                                .foregroundColor(.secondary)
                                .padding(.vertical, 8)
                        }
                        
                        HStack(alignment: .bottom) {
                            if log.isUser {
                                Spacer()
                                VStack(alignment: .trailing, spacing: 4) {
                                    Text(log.translated).font(.headline).foregroundColor(.white)
                                    Text(log.original).font(.subheadline).foregroundColor(.white.opacity(0.8))
                                    // ログの一言一言に時間を追加
                                    Text(timeFormatter.string(from: log.timestamp))
                                        .font(.caption2)
                                        .foregroundColor(.white.opacity(0.6))
                                }
                                .padding()
                                .background(Color.orange)
                                .cornerRadius(12)
                            } else {
                                VStack(alignment: .leading, spacing: 4) {
                                    Text(log.translated).font(.headline).foregroundColor(.white)
                                    Text(log.original).font(.subheadline).foregroundColor(.white.opacity(0.8))
                                    // ログの一言一言に時間を追加
                                    Text(timeFormatter.string(from: log.timestamp))
                                        .font(.caption2)
                                        .foregroundColor(.white.opacity(0.6))
                                }
                                .padding()
                                .background(Color.blue)
                                .cornerRadius(12)
                                Spacer()
                            }
                        }
                    }
                }
                .padding()
            }
            .navigationTitle("会話履歴")
            .navigationBarTitleDisplayMode(.inline)
            .toolbar {
                ToolbarItem(placement: .navigationBarLeading) {
                    Button(role: .destructive) { showDeleteConfirm = true } label: {
                        Image(systemName: "trash")
                        Text("消去")
                    }
                }
                ToolbarItem(placement: .navigationBarTrailing) {
                    HStack {
                        if !vm.logs.isEmpty {
                            ShareLink(item: vm.shareText) {
                                Image(systemName: "square.and.arrow.up")
                                Text("共有")
                            }
                        }
                        Button("閉じる") { dismiss() }
                    }
                }
            }
            .alert("履歴をすべて消去しますか？", isPresented: $showDeleteConfirm) {
                Button("キャンセル", role: .cancel) { }
                Button("消去する", role: .destructive) { vm.clearLogs() }
            }
        }
    }
}

