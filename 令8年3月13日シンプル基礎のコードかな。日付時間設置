import Foundation



final class LogStorage {
    static let shared = LogStorage()
    private let fileURL: URL

    private init() {
        let dir = FileManager.default.urls(for: .documentDirectory, in: .userDomainMask).first!
        self.fileURL = dir.appendingPathComponent("conversation_logs.json")
    }

    func save(_ logs: [ConversationLog]) {
        do {
            let data = try JSONEncoder().encode(logs)
            try data.write(to: fileURL)
        } catch {
            print("ログ保存失敗: \(error)")
        }
    }

    func load() -> [ConversationLog] {
        do {
            let data = try Data(contentsOf: fileURL)
            let logs = try JSONDecoder().decode([ConversationLog].self, from: data)
            return logs
        } catch {
            return []
        }
    }
}

// =====================================
// DoujituVM の拡張（追加のみ）
// =====================================

extension DoujituVM {

    // アプリ起動時に呼ぶための関数
    func loadSavedLogs() {
        let loaded = LogStorage.shared.load()
        if !loaded.isEmpty {
            self.logs = loaded
        }
    }

    // override 的に呼ばれる記録処理（既存コードに追加）
    func addToLogWithDateCheck(original: String, translated: String, isUser: Bool) {

        // --- 日付区切り挿入 ---
        if let last = logs.last {
            let lastDay = Calendar.current.startOfDay(for: last.timestamp)
            let today = Calendar.current.startOfDay(for: Date())

            if lastDay != today {
                let formatter = DateFormatter()
                formatter.dateFormat = "yyyy/MM/dd"
                let dateString = formatter.string(from: Date())

                let separator = ConversationLog(
                    original: "——— \(dateString) ———",
                    translated: "",
                    isUser: false
                )
                logs.append(separator)
            }
        }

        // 実際のログ追加（既存メソッドを呼ぶ）
        self.addToLog(original: original, translated: translated, isUser: isUser)

        // 永続化
        LogStorage.shared.save(logs)
    }
}

